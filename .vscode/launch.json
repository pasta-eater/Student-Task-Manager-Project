{
    "version": "0.2.0",
    "configurations": [
        {
            "name": ".NET Core Launch (console)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            // This line tells VS Code to find the .dll automatically
            "program": "${workspaceFolder}/StuTaskManager/bin/Debug/net10.0/StuTaskManager.dll",
            "args": [],
            "cwd": "${workspaceFolder}/StuTaskManager",
            "stopAtEntry": false,
            "console": "externalTerminal"
        }
    ]
}